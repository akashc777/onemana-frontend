# Public config for the OneMana marketing site + storefront.
# Copy to .env.local for local dev; set in Vercel/Cloudflare for production.

# onemana-backend base URL (no trailing slash).
NEXT_PUBLIC_BACKEND_URL=https://backend.onemana.dev
# OneCamp live demo workspace.
NEXT_PUBLIC_DEMO_URL=https://onecamp.onemana.dev
# Open-source frontend repo.
NEXT_PUBLIC_GITHUB_URL=https://github.com/OneMana-Soft/OneCamp-fe
# owner/repo used to fetch live star count.
NEXT_PUBLIC_GITHUB_REPO=OneMana-Soft/OneCamp-fe
